# ============================================================
# HESAKA Plantilla - Variables de entorno del backend
# Copiar este archivo como .env solo para pruebas locales.
# En produccion, cargar estos valores en Railway.
# ============================================================

# Base de datos administrativa
ADMIN_DATABASE_URL=postgresql://postgres:password@localhost:5432/hesaka_admin

# Prefijo de bases de datos de clientes
TENANT_DB_PREFIX=hesaka_

# Slug del cliente actual
# Ejemplo para Koeti: koeti
DEFAULT_TENANT_SLUG=demo

# Servidor PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# Replica local opcional
REPLICA_POSTGRES_HOST=localhost
REPLICA_POSTGRES_PORT=5432
REPLICA_POSTGRES_USER=postgres
REPLICA_POSTGRES_PASSWORD=your_local_replica_password_here
REPLICA_TENANT_DB_PREFIX=hesaka_
SYNC_BATCH_SIZE=1000

# Seguridad
SECRET_KEY=cambia_esta_clave_secreta_muy_larga_y_segura_en_produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS
CORS_ORIGINS=http://localhost:5173,https://*.hesaka.com

# Ambiente
ENVIRONMENT=development

