# ============================================================
# HESAKA Koeti - ejemplo de variables del backend
# Cargar estos valores en Railway para la instancia Koeti.
# ============================================================

# Base administrativa del proyecto Koeti
ADMIN_DATABASE_URL=postgresql://postgres:password@HOST:PORT/hesaka_admin

# Prefijo de bases de datos de clientes
TENANT_DB_PREFIX=hesaka_

# Slug del cliente
DEFAULT_TENANT_SLUG=koeti

# Servidor PostgreSQL del proyecto Koeti
POSTGRES_HOST=HOST
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# Replica local opcional
REPLICA_POSTGRES_HOST=localhost
REPLICA_POSTGRES_PORT=5432
REPLICA_POSTGRES_USER=postgres
REPLICA_POSTGRES_PASSWORD=password
REPLICA_TENANT_DB_PREFIX=hesaka_
SYNC_BATCH_SIZE=1000

# Seguridad
SECRET_KEY=cambiar_por_una_clave_larga_y_segura
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Frontend autorizado
CORS_ORIGINS=http://localhost:5173,https://hesaka-koeti.vercel.app

# Ambiente
ENVIRONMENT=production

